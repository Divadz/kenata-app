# Configuration Firebase (client) — copier ce fichier en `.env.local` et remplir.
# Ces valeurs sont publiques par nature (elles finissent dans le bundle) ;
# la sécurité repose sur les règles Realtime Database + Firebase Auth, PAS sur ces clés.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Identifiant du groupe unique (single-tenant). Ex. "kenata".
VITE_GROUP_ID=kenata
