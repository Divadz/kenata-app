{
  "rules": {
    ".read": false,
    ".write": false,

    "groups": {
      "$gid": {

        "meta": {
          ".read": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()",
          ".write": "auth != null && (root.child('groups').child($gid).child('members').child(auth.uid).child('role').val() == 'owner' || root.child('groups').child($gid).child('members').child(auth.uid).child('role').val() == 'admin')"
        },

        "members": {
          ".read": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()",
          "$uid": {
            ".write": "auth != null && ( root.child('groups').child($gid).child('members').child(auth.uid).child('role').val() == 'owner' || ( (root.child('groups').child($gid).child('members').child(auth.uid).child('role').val() == 'admin') && data.child('role').val() != 'owner' && (!newData.exists() || newData.child('role').val() != 'owner') ) )",
            "role": {
              ".validate": "newData.isString() && newData.val().matches(/^(owner|admin|member)$/)"
            },
            "profile": {
              ".write": "auth != null && ( (auth.uid == $uid && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()) || ( (root.child('groups').child($gid).child('members').child(auth.uid).child('role').val() == 'owner') || ((root.child('groups').child($gid).child('members').child(auth.uid).child('role').val() == 'admin') && data.parent().child('role').val() != 'owner') ) )"
            }
          }
        },

        "invitations": {
          ".read": "auth != null && (root.child('groups').child($gid).child('members').child(auth.uid).child('role').val() == 'owner' || root.child('groups').child($gid).child('members').child(auth.uid).child('role').val() == 'admin')",
          ".write": "auth != null && (root.child('groups').child($gid).child('members').child(auth.uid).child('role').val() == 'owner' || root.child('groups').child($gid).child('members').child(auth.uid).child('role').val() == 'admin')",
          "$inviteId": {
            ".validate": "newData.hasChildren(['email', 'role']) && newData.child('role').val().matches(/^(admin|member)$/)"
          }
        },

        "songs": {
          ".read": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()",
          ".write": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()"
        },
        "songSheets": {
          ".read": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()",
          ".write": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()"
        },
        "setlists": {
          ".read": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()",
          ".write": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()"
        },
        "concerts": {
          ".read": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()",
          ".write": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()"
        },
        "gearTemplates": {
          ".read": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()",
          ".write": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()"
        },
        "booking": {
          ".read": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()",
          ".write": "auth != null && root.child('groups').child($gid).child('members').child(auth.uid).child('role').exists()"
        }
      }
    }
  }
}
